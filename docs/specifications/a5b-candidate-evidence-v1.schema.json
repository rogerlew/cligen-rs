{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rogerlew/cligen-rs/main/docs/specifications/a5b-candidate-evidence-v1.schema.json",
  "title": "A5b sealed candidate evidence manifest revision 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_evidence_manifest_version",
    "status",
    "contracts",
    "corpus",
    "matrix",
    "fit",
    "build",
    "shared_bases",
    "archives",
    "runs",
    "execution"
  ],
  "properties": {
    "candidate_evidence_manifest_version": { "const": 1 },
    "status": { "const": "sealed" },
    "contracts": {
      "type": "object",
      "minProperties": 10,
      "additionalProperties": { "$ref": "#/$defs/identity" }
    },
    "corpus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "content_sha256", "station_ids"],
      "properties": {
        "schema_version": { "const": 1 },
        "content_sha256": { "$ref": "#/$defs/sha256" },
        "station_ids": {
          "type": "array",
          "minItems": 17,
          "maxItems": 17,
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z]{2}[0-9]{6}$" }
        }
      }
    },
    "matrix": {
      "type": "object",
      "additionalProperties": false,
      "required": ["horizons", "replicates", "candidates", "expected_runs"],
      "properties": {
        "horizons": {
          "type": "array",
          "prefixItems": [{ "const": 30 }, { "const": 100 }],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "replicates": {
          "type": "array",
          "minItems": 8,
          "maxItems": 8,
          "items": { "$ref": "#/$defs/replicate" }
        },
        "candidates": {
          "type": "array",
          "minItems": 7,
          "maxItems": 7,
          "items": { "$ref": "#/$defs/candidate" }
        },
        "expected_runs": { "const": 1904 }
      }
    },
    "fit": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source_manifest", "fit_manifest", "bundles"],
      "properties": {
        "source_manifest": { "$ref": "#/$defs/artifact" },
        "fit_manifest": { "$ref": "#/$defs/artifact" },
        "bundles": {
          "type": "array",
          "minItems": 17,
          "maxItems": 17,
          "items": { "$ref": "#/$defs/artifact" }
        }
      }
    },
    "build": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_commit", "cligen_binary", "overlay_binary", "cargo_lock_sha256", "rustc_version", "plan_preflight"],
      "properties": {
        "implementation_commit": { "$ref": "#/$defs/git_commit" },
        "cligen_binary": { "$ref": "#/$defs/artifact" },
        "overlay_binary": { "$ref": "#/$defs/artifact" },
        "cargo_lock_sha256": { "$ref": "#/$defs/sha256" },
        "rustc_version": { "type": "string", "minLength": 1 },
        "plan_preflight": {
          "type": "object",
          "additionalProperties": false,
          "required": ["plans", "aggregate_sha256"],
          "properties": {
            "plans": { "const": 952 },
            "aggregate_sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "shared_bases": {
      "type": "object",
      "additionalProperties": false,
      "required": ["format", "artifact", "base_count", "member_count", "records"],
      "properties": {
        "format": { "const": "tar+gzip-canonical-v1" },
        "artifact": { "$ref": "#/$defs/artifact" },
        "base_count": { "const": 272 },
        "member_count": { "const": 544 },
        "records": {
          "type": "array",
          "minItems": 272,
          "maxItems": 272,
          "items": { "$ref": "#/$defs/shared_base" }
        }
      }
    },
    "archives": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["candidate_id", "format", "artifact", "member_count"],
        "properties": {
          "candidate_id": { "$ref": "#/$defs/candidate_id" },
          "format": { "const": "tar+gzip-canonical-v1" },
          "artifact": { "$ref": "#/$defs/artifact" },
          "member_count": { "type": "integer", "minimum": 1 }
        }
      }
    },
    "runs": {
      "type": "array",
      "minItems": 1904,
      "maxItems": 1904,
      "items": { "$ref": "#/$defs/run_index" }
    },
    "execution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workers", "started_utc", "completed_utc", "wall_time_seconds", "failures", "candidate_cli_bytes_removed_after_wepp"],
      "properties": {
        "workers": { "type": "integer", "minimum": 1 },
        "started_utc": { "type": "string", "format": "date-time" },
        "completed_utc": { "type": "string", "format": "date-time" },
        "wall_time_seconds": { "type": "number", "minimum": 0 },
        "failures": { "type": "array", "maxItems": 0 },
        "candidate_cli_bytes_removed_after_wepp": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "git_commit": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
    "candidate_id": {
      "enum": [
        "rank_one_monthly_sd",
        "full_monthly_covariance",
        "fourier_eof",
        "vector_ar",
        "gaussian_hmm",
        "spectral_random_phase",
        "precip_counterfactual"
      ]
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "sha256", "bytes"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "replicate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["replicate", "legacy_burn", "extension_seed"],
      "properties": {
        "replicate": { "type": "integer", "minimum": 0, "maximum": 7 },
        "legacy_burn": { "enum": [0, 17, 101, 503, 1009, 5003, 10007, 50021] },
        "extension_seed": { "type": "string", "pattern": "^0x[0-9a-f]{16}$" }
      }
    },
    "candidate": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate_id", "station_model", "generation_profile"],
      "properties": {
        "candidate_id": { "$ref": "#/$defs/candidate_id" },
        "station_model": { "type": "string", "minLength": 1 },
        "generation_profile": { "type": "string", "minLength": 1 }
      }
    },
    "run_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "station_id",
        "regime",
        "candidate_id",
        "horizon_years",
        "replicate",
        "legacy_burn",
        "extension_seed",
        "archive_candidate_id",
        "run_record",
        "quality_report",
        "overlay_diagnostics",
        "plan",
        "candidate_cli_sha256",
        "candidate_cli_bytes"
      ],
      "properties": {
        "station_id": { "type": "string", "pattern": "^[a-z]{2}[0-9]{6}$" },
            "regime": {
              "enum": ["arid", "monsoonal", "humid", "cold", "fixture"]
            },
        "candidate_id": { "$ref": "#/$defs/candidate_id" },
        "horizon_years": { "enum": [30, 100] },
        "replicate": { "type": "integer", "minimum": 0, "maximum": 7 },
        "legacy_burn": { "enum": [0, 17, 101, 503, 1009, 5003, 10007, 50021] },
        "extension_seed": { "type": "string", "pattern": "^0x[0-9a-f]{16}$" },
        "archive_candidate_id": { "$ref": "#/$defs/candidate_id" },
        "run_record": { "$ref": "#/$defs/member" },
        "quality_report": { "$ref": "#/$defs/member" },
        "overlay_diagnostics": { "$ref": "#/$defs/member" },
        "plan": { "$ref": "#/$defs/member" },
        "candidate_cli_sha256": { "$ref": "#/$defs/sha256" },
        "candidate_cli_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["member", "sha256", "bytes"],
      "properties": {
        "member": { "type": "string", "minLength": 1 },
        "sha256": { "$ref": "#/$defs/sha256" },
        "bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "shared_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "station_id",
        "horizon_years",
        "replicate",
        "legacy_burn",
        "runspec",
        "provenance",
        "base_cli_sha256",
        "base_run_id",
        "parameter_set_sha256"
      ],
      "properties": {
        "station_id": { "type": "string", "pattern": "^[a-z]{2}[0-9]{6}$" },
        "horizon_years": { "enum": [30, 100] },
        "replicate": { "type": "integer", "minimum": 0, "maximum": 7 },
        "legacy_burn": { "enum": [0, 17, 101, 503, 1009, 5003, 10007, 50021] },
        "runspec": { "$ref": "#/$defs/member" },
        "provenance": { "$ref": "#/$defs/member" },
        "base_cli_sha256": { "$ref": "#/$defs/sha256" },
        "base_run_id": { "$ref": "#/$defs/sha256" },
        "parameter_set_sha256": { "$ref": "#/$defs/sha256" }
      }
    }
  }
}
