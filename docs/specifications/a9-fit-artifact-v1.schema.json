{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogerlew/cligen-rs/blob/main/docs/specifications/a9-fit-artifact-v1.schema.json",
  "title": "A9 research fit artifact v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "fit_id",
    "content_sha256",
    "fit_status",
    "model_family_id",
    "candidate_class",
    "fit_role",
    "station_scope",
    "sources",
    "preprocessing",
    "pooling",
    "optimizer",
    "rng",
    "parameters",
    "diagnostics",
    "provenance"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "fit_id": { "$ref": "#/$defs/id" },
    "content_sha256": { "$ref": "#/$defs/sha256" },
    "fit_status": {
      "enum": ["fit_valid", "fit_ineligible", "fit_failed"]
    },
    "status_reason": { "type": ["string", "null"], "minLength": 1 },
    "model_family_id": { "const": "a9_joint_daily_event_family_v1" },
    "candidate_class": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "schema_version", "schema_sha256", "source_sha256"],
      "properties": {
        "id": {
          "enum": [
            "alternating_renewal_marked_v1",
            "latent_regime_marked_v1"
          ]
        },
        "schema_version": { "type": "integer", "minimum": 1 },
        "schema_sha256": { "$ref": "#/$defs/sha256" },
        "source_sha256": { "$ref": "#/$defs/sha256" }
      }
    },
    "fit_role": { "const": "coefficient_fit" },
    "station_scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["scope", "stations", "group_id"],
      "properties": {
        "scope": {
          "enum": ["station", "regional_pool", "hierarchical_pool"]
        },
        "stations": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["station_id", "latitude", "longitude"],
            "properties": {
              "station_id": { "$ref": "#/$defs/id" },
              "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
              "longitude": { "type": "number", "minimum": -180, "maximum": 180 },
              "elevation_m": { "type": ["number", "null"] }
            }
          }
        },
        "group_id": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/source" }
    },
    "preprocessing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "recipe_id",
        "recipe_sha256",
        "wet_thresholds_mm",
        "detrending",
        "missingness_rule",
        "event_segmentation_id"
      ],
      "properties": {
        "recipe_id": { "$ref": "#/$defs/id" },
        "recipe_sha256": { "$ref": "#/$defs/sha256" },
        "wet_thresholds_mm": {
          "type": "object",
          "additionalProperties": false,
          "required": ["wet0_exclusive", "r1mm_inclusive"],
          "properties": {
            "wet0_exclusive": { "const": 0.0 },
            "r1mm_inclusive": { "const": 1.0 }
          }
        },
        "detrending": { "type": "string", "minLength": 1 },
        "missingness_rule": { "type": "string", "minLength": 1 },
        "event_segmentation_id": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "pooling": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "membership_sha256", "selected_before_fit"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/id" },
        "membership_sha256": { "$ref": "#/$defs/sha256" },
        "selected_before_fit": { "const": true }
      }
    },
    "optimizer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "configuration_sha256",
        "parameter_bounds_sha256",
        "stopping_rule",
        "evaluation_budget",
        "wall_time_seconds",
        "memory_bytes"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "version": { "type": "string", "minLength": 1 },
        "configuration_sha256": { "$ref": "#/$defs/sha256" },
        "parameter_bounds_sha256": { "$ref": "#/$defs/sha256" },
        "stopping_rule": { "type": "string", "minLength": 1 },
        "evaluation_budget": { "type": "integer", "minimum": 1 },
        "wall_time_seconds": { "type": "integer", "minimum": 1 },
        "memory_bytes": { "type": "integer", "minimum": 1 }
      }
    },
    "rng": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fit", "optimizer", "parameter_member"],
      "properties": {
        "fit": { "$ref": "#/$defs/rngIdentity" },
        "optimizer": { "$ref": "#/$defs/rngIdentity" },
        "parameter_member": { "$ref": "#/$defs/rngIdentity" }
      }
    },
    "parameters": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "value", "unit", "support"],
        "properties": {
          "name": { "$ref": "#/$defs/id" },
          "value": {
            "oneOf": [
              { "type": "number" },
              { "type": "array", "items": { "type": "number" } },
              {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": { "type": "number" }
                }
              }
            ]
          },
          "unit": { "type": "string", "minLength": 1 },
          "support": { "type": "string", "minLength": 1 }
        }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "effective_exposures",
        "identifiability",
        "hard_checks",
        "monthly_moment_checks",
        "uncertainty"
      ],
      "properties": {
        "effective_exposures": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 0 }
        },
        "identifiability": {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "method", "details_sha256"],
          "properties": {
            "status": { "enum": ["pass", "fail", "unavailable"] },
            "method": { "type": "string", "minLength": 1 },
            "details_sha256": { "$ref": "#/$defs/sha256" }
          }
        },
        "hard_checks": {
          "type": "array",
          "items": { "$ref": "#/$defs/check" }
        },
        "monthly_moment_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "status",
              "value",
              "tolerance",
              "month_length_days",
              "quadrature_id"
            ],
            "properties": {
              "id": { "$ref": "#/$defs/id" },
              "status": { "enum": ["pass", "fail", "unavailable"] },
              "value": { "type": ["number", "string", "null"] },
              "tolerance": { "type": ["number", "string", "null"] },
              "month_length_days": {
                "type": "integer",
                "enum": [28, 29, 30, 31]
              },
              "quadrature_id": { "$ref": "#/$defs/id" }
            }
          }
        },
        "uncertainty": {
          "type": "object",
          "additionalProperties": false,
          "required": ["method", "member_id", "details_sha256"],
          "properties": {
            "method": { "type": "string", "minLength": 1 },
            "member_id": { "type": ["string", "null"], "minLength": 1 },
            "details_sha256": { "$ref": "#/$defs/sha256" }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "created_at",
        "software_version",
        "git_commit",
        "git_dirty",
        "objective_registry_sha256",
        "data_role_manifest_sha256",
        "parent_hashes"
      ],
      "properties": {
        "created_at": { "type": "string", "format": "date-time" },
        "software_version": { "type": "string", "minLength": 1 },
        "git_commit": { "$ref": "#/$defs/gitCommit" },
        "git_dirty": { "type": "boolean" },
        "objective_registry_sha256": { "$ref": "#/$defs/sha256" },
        "data_role_manifest_sha256": { "$ref": "#/$defs/sha256" },
        "parent_hashes": {
          "type": "array",
          "items": { "$ref": "#/$defs/sha256" },
          "uniqueItems": true
        }
      }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "gitCommit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "rngIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "version", "domain", "seed_hex"],
      "properties": {
        "algorithm": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "domain": { "type": "string", "minLength": 1 },
        "seed_hex": {
          "type": "string",
          "pattern": "^[0-9a-f]{16,128}$"
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_id",
        "product",
        "version",
        "object_sha256",
        "logical_sha256",
        "station_id",
        "variables",
        "units",
        "calendar",
        "day_boundary",
        "period_start",
        "period_end",
        "missingness",
        "accessed_at"
      ],
      "properties": {
        "source_id": { "$ref": "#/$defs/id" },
        "product": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "object_sha256": { "$ref": "#/$defs/sha256" },
        "logical_sha256": { "$ref": "#/$defs/sha256" },
        "station_id": { "$ref": "#/$defs/id" },
        "variables": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "units": {
          "type": "object",
          "additionalProperties": { "type": "string", "minLength": 1 }
        },
        "calendar": { "type": "string", "minLength": 1 },
        "day_boundary": { "type": "string", "minLength": 1 },
        "period_start": { "type": "string", "format": "date" },
        "period_end": { "type": "string", "format": "date" },
        "missingness": { "type": "string", "minLength": 1 },
        "accessed_at": { "type": "string", "format": "date-time" }
      }
    },
    "check": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "status", "value", "tolerance"],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "status": { "enum": ["pass", "fail", "unavailable"] },
        "value": { "type": ["number", "string", "null"] },
        "tolerance": { "type": ["number", "string", "null"] }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "fit_status": { "const": "fit_valid" } },
        "required": ["fit_status"]
      },
      "then": {
        "properties": {
          "status_reason": { "type": "null" },
          "parameters": { "minItems": 1 }
        }
      },
      "else": {
        "required": ["status_reason"],
        "properties": { "parameters": { "maxItems": 0 } }
      }
    }
  ]
}
