{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogerlew/cligen-rs/docs/specifications/station-document-v2.schema.json",
  "title": "CLIGEN A8c routed station document",
  "description": "SPEC-A8C-ROUTED-DAILY station document revision 2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "station_schema_version",
    "station_model",
    "units",
    "lineage",
    "parameters",
    "daily_precipitation"
  ],
  "properties": {
    "station_schema_version": {"const": 2},
    "station_model": {
      "enum": ["fixed_monthly_5_32_3", "a8c_integrated_daily_v1"]
    },
    "units": {
      "$ref": "station-document.schema.json#/$defs/units"
    },
    "lineage": {
      "$ref": "station-document.schema.json#/$defs/lineage"
    },
    "parameters": {
      "$ref": "station-document.schema.json#/$defs/parameters"
    },
    "daily_precipitation": {"$ref": "#/$defs/dailyPrecipitation"}
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "finiteF64": {
      "type": "number"
    },
    "dailyPrecipitation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "fit_id",
        "source_analysis_sha256",
        "seasons",
        "months"
      ],
      "properties": {
        "route": {"enum": ["integrated_daily", "legacy_daily_fallback"]},
        "fit_id": {"type": "string", "minLength": 1},
        "source_analysis_sha256": {"$ref": "#/$defs/sha256"},
        "seasons": {
          "type": "array",
          "items": {"$ref": "#/$defs/season"},
          "maxItems": 4
        },
        "months": {
          "type": "array",
          "items": {"$ref": "#/$defs/month"},
          "maxItems": 12
        }
      },
      "allOf": [
        {
          "if": {"properties": {"route": {"const": "integrated_daily"}}},
          "then": {
            "properties": {
              "fit_id": {"const": "a8a_o2_logqspline_gaussian_copula_v1"},
              "source_analysis_sha256": {
                "const": "78b9b9bb5cd5172459bfb27ba13f7b20ca2cec5af19cab9547c425c7a6e6e89b"
              },
              "seasons": {"minItems": 4},
              "months": {"minItems": 12}
            }
          },
          "else": {
            "properties": {
              "fit_id": {"const": "legacy_daily_only_v1"},
              "source_analysis_sha256": {
                "const": "b227951faa72287afd859fb9872eb75aa559714ab6b5efd2303560b73e5a1efb"
              },
              "seasons": {"maxItems": 0},
              "months": {"maxItems": 0}
            }
          }
        }
      ]
    },
    "season": {
      "type": "object",
      "additionalProperties": false,
      "required": ["season", "log_quantile_knots_mm", "gaussian_copula_rho"],
      "properties": {
        "season": {"enum": ["DJF", "MAM", "JJA", "SON"]},
        "log_quantile_knots_mm": {
          "type": "array",
          "minItems": 11,
          "maxItems": 11,
          "items": {"type": "number", "exclusiveMinimum": 0}
        },
        "gaussian_copula_rho": {
          "type": "number",
          "minimum": -0.95,
          "maximum": 0.95
        }
      }
    },
    "month": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "month",
        "occurrence_probabilities",
        "amount_dispersion",
        "legacy_amount_dispersion"
      ],
      "properties": {
        "month": {"type": "integer", "minimum": 1, "maximum": 12},
        "occurrence_probabilities": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {"type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1}
        },
        "amount_dispersion": {"type": "number", "exclusiveMinimum": 0},
        "legacy_amount_dispersion": {"type": "number", "exclusiveMinimum": 0}
      }
    }
  },
  "allOf": [
    {
      "if": {"properties": {"station_model": {"const": "a8c_integrated_daily_v1"}}},
      "then": {
        "properties": {
          "daily_precipitation": {
            "properties": {"route": {"const": "integrated_daily"}}
          }
        }
      },
      "else": {
        "properties": {
          "daily_precipitation": {
            "properties": {"route": {"const": "legacy_daily_fallback"}}
          }
        }
      }
    }
  ]
}
