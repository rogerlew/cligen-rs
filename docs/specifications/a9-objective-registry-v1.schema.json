{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogerlew/cligen-rs/blob/main/docs/specifications/a9-objective-registry-v1.schema.json",
  "title": "A9 objective registry v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "registry_id",
    "horizons_years",
    "null_calibration",
    "aggregation",
    "objectives"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "registry_id": { "$ref": "#/$defs/id" },
    "horizons_years": {
      "type": "array",
      "prefixItems": [
        { "const": 30 },
        { "const": 100 }
      ],
      "items": false
    },
    "null_calibration": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "familywise_alpha",
        "method",
        "replicates",
        "baseline_zero_rule",
        "candidate_access_prohibited"
      ],
      "properties": {
        "familywise_alpha": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 1
        },
        "method": { "const": "paired_max_statistic_quantile" },
        "replicates": { "type": "integer", "minimum": 100 },
        "baseline_zero_rule": { "type": "string", "minLength": 1 },
        "candidate_access_prohibited": { "const": true }
      }
    },
    "aggregation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "station_to_stratum",
        "mandatory_strata",
        "minimum_available_stations_per_stratum",
        "selection_rule"
      ],
      "properties": {
        "station_to_stratum": { "const": "median_with_uncertainty" },
        "mandatory_strata": {
          "type": "array",
          "minItems": 6,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/stratum" }
        },
        "minimum_available_stations_per_stratum": {
          "type": "integer",
          "minimum": 1
        },
        "selection_rule": { "const": "a9_lexicographic_pareto_v1" }
      }
    },
    "objectives": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/objective" }
    }
  },
  "$defs": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._-]{0,127}$"
    },
    "stratum": {
      "enum": [
        "hot_arid",
        "arid_boundary",
        "monsoonal_transition",
        "non_monsoonal_semi_arid",
        "humid",
        "cold"
      ]
    },
    "objective": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "family",
        "statistic",
        "target_units",
        "estimator",
        "distance",
        "direction",
        "normalization",
        "baseline_zero",
        "aggregation",
        "minimum_support",
        "unavailable_rule",
        "uncertainty",
        "selection_role",
        "horizons_years",
        "required_variables"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/id" },
        "family": {
          "enum": [
            "engineering",
            "occurrence_spell",
            "wet_amount",
            "aggregate",
            "extreme",
            "storm_descriptor",
            "compound_context",
            "winter_proxy"
          ]
        },
        "statistic": { "type": "string", "minLength": 1 },
        "target_units": { "type": "string", "minLength": 1 },
        "estimator": { "type": "string", "minLength": 1 },
        "distance": { "type": "string", "minLength": 1 },
        "direction": {
          "enum": [
            "minimize_distance",
            "must_pass",
            "report_only"
          ]
        },
        "normalization": { "type": "string", "minLength": 1 },
        "absolute_floor": { "type": ["number", "null"], "minimum": 0 },
        "baseline_zero": {
          "enum": [
            "absolute_floor",
            "two_part_zero_mass_and_positive_scale",
            "not_applicable"
          ]
        },
        "aggregation": { "type": "string", "minLength": 1 },
        "minimum_support": { "type": "string", "minLength": 1 },
        "unavailable_rule": { "type": "string", "minLength": 1 },
        "uncertainty": { "type": "string", "minLength": 1 },
        "selection_role": {
          "enum": ["mandatory", "secondary", "report_only", "hard_invariant"]
        },
        "horizons_years": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "enum": [30, 100] }
        },
        "required_variables": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/id" }
        },
        "notes": { "type": "string", "minLength": 1 }
      }
    }
  }
}
