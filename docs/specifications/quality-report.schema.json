        },
        "dewpoint_mean_c": {
          "$ref": "#/$defs/par_parameter"
        },
        "wind_speed_mean_ms": {
          "$ref": "#/$defs/par_parameter"
        }
      }
    },
    "dispersion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mean",
        "sd",
        "cv",
        "n_years"
      ],
      "properties": {
        "mean": {
