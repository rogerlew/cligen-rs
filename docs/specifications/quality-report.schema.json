{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/rogerlew/cligen-rs/blob/main/docs/specifications/quality-report.schema.json",
  "title": "cligen-rs quality report metrics_version 2",
  "description": "Full SPEC-QUALITY-REPORT envelope. Object properties are declared in the deterministic serialization order used by the Rust structs.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "metrics_version",
    "identity",
    "par_convergence",
    "interannual",
    "covariation",
    "tails",
    "process"
  ],
  "properties": {
    "metrics_version": {
      "const": 2
    },
    "identity": {
      "$ref": "#/$defs/identity"
    },
    "par_convergence": {
      "anyOf": [
        {
          "$ref": "#/$defs/par_convergence"
        },
        {
          "type": "null"
        }
      ]
    },
    "interannual": {
      "anyOf": [
        {
          "$ref": "#/$defs/interannual"
        },
        {
          "type": "null"
        }
      ]
    },
    "covariation": {
      "anyOf": [
        {
          "$ref": "#/$defs/covariation"
        },
        {
          "type": "null"
        }
      ]
    },
    "tails": {
      "$ref": "#/$defs/tails"
    },
    "process": {
      "anyOf": [
        {
          "$ref": "#/$defs/process"
        },
        {
          "type": "null"
        }
      ]
    }
  },
  "$defs": {
    "nullable_number": {
      "type": [
        "number",
        "null"
      ]
    },
    "nullable_integer": {
      "type": [
        "integer",
        "null"
      ]
    },
    "nullable_boolean": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "nonnegative_integer": {
      "type": "integer",
      "minimum": 0
    },
    "identity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "content",
        "provenance"
      ],
      "properties": {
        "content": {
          "$ref": "#/$defs/identity_content"
        },
        "provenance": {
          "anyOf": [
            {
              "$ref": "#/$defs/provenance"
            },
            {
              "type": "null"
            }
          ]
        }
      }
    },
    "identity_content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "par_sha256",
        "cli_sha256",
        "days",
        "years",
        "span"
      ],
      "properties": {
        "tool": {
          "type": "string"
        },
        "par_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "cli_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "days": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "years": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "span": {
          "type": "array",
          "minItems": 2,
          "maxItems": 2,
          "items": {
            "type": "integer"
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "generation_profile",
        "qc_filter",
        "mode",
        "burn",
        "begin_year",
        "years",
        "interpolation"
      ],
      "properties": {
        "generation_profile": {
          "enum": [
            "faithful_5_32_3",
            "fast_batch_v0"
          ]
        },
        "qc_filter": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "faithful",
            null
          ]
        },
        "mode": {
          "enum": [
            "continuous",
            "observed",
            "single_storm",
            "design_storm"
          ]
        },
        "burn": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "begin_year": {
          "$ref": "#/$defs/nullable_integer"
        },
        "years": {
          "$ref": "#/$defs/nullable_integer"
        },
        "interpolation": {
          "enum": [
            "none",
            "linear",
            "fourier",
            "monthly_mean_preserving"
          ]
        }
      }
    },
    "par_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target",
        "generated",
        "abs_err",
        "rel_err",
        "n"
      ],
      "properties": {
        "target": {
          "$ref": "#/$defs/nullable_number"
        },
        "generated": {
          "$ref": "#/$defs/nullable_number"
        },
        "abs_err": {
          "$ref": "#/$defs/nullable_number"
        },
        "rel_err": {
          "$ref": "#/$defs/nullable_number"
        },
        "n": {
          "$ref": "#/$defs/nonnegative_integer"
        }
      }
    },
    "months_par_cell": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "jan",
        "feb",
        "mar",
        "apr",
        "may",
        "jun",
        "jul",
        "aug",
        "sep",
        "oct",
        "nov",
        "dec"
      ],
      "properties": {
        "jan": {
          "$ref": "#/$defs/par_cell"
        },
        "feb": {
          "$ref": "#/$defs/par_cell"
        },
        "mar": {
          "$ref": "#/$defs/par_cell"
        },
        "apr": {
          "$ref": "#/$defs/par_cell"
        },
        "may": {
          "$ref": "#/$defs/par_cell"
        },
        "jun": {
          "$ref": "#/$defs/par_cell"
        },
        "jul": {
          "$ref": "#/$defs/par_cell"
        },
        "aug": {
          "$ref": "#/$defs/par_cell"
        },
        "sep": {
