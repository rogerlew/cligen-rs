        },
        "by_decade": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/par_decade"
          }
        }
      }
    },
    "par_decade": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "decade",
        "start_year",
        "n_years",
        "months"
      ],
      "properties": {
        "decade": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "start_year": {
          "type": "integer"
        },
        "n_years": {
          "$ref": "#/$defs/nonnegative_integer"
        },
        "months": {
          "$ref": "#/$defs/months_par_cell"
        }
      }
    },
    "par_convergence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "observed_passthrough",
        "precip_wet_mean_mm",
        "precip_wet_sd_mm",
        "precip_wet_skew",
        "wet_day_fraction",
        "p_ww",
        "p_wd",
        "tmax_mean_c",
        "tmax_sd_c",
        "tmin_mean_c",
        "tmin_sd_c",
        "radiation_mean_ly",
        "dewpoint_mean_c",
        "wind_speed_mean_ms"
      ],
      "properties": {
        "observed_passthrough": {
          "$ref": "#/$defs/nullable_boolean"
        },
        "precip_wet_mean_mm": {
          "$ref": "#/$defs/par_parameter"
        },
        "precip_wet_sd_mm": {
          "$ref": "#/$defs/par_parameter"
