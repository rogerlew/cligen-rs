    "median": "middle_order_statistic_if_odd_else_arithmetic_mean_of_two_middle_order_statistics",
    "replicate_interval": "nearest_rank_p05_and_p95_of_empirical_replicate_values",
    "station_pooling": "forbidden",
    "unequal_weighting": "forbidden"
