{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/rogerlew/cligen-rs/main/docs/specifications/a5b-augmented-station-v1.schema.json",
  "title": "A5b coefficient-augmented experimental station bundle revision 1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "station_schema_version",
    "station_document_role",
    "station_id",
    "base_station",
    "source_lineage",
    "fit_contract",
    "extensions"
  ],
  "properties": {
    "station_schema_version": { "const": 2 },
    "station_document_role": { "const": "a5b_interannual_candidate_bundle_v1" },
    "station_id": { "type": "string", "pattern": "^[a-z]{2}[0-9]{6}$" },
    "base_station": { "$ref": "station-document.schema.json" },
    "source_lineage": { "$ref": "#/$defs/source_lineage" },
    "fit_contract": { "$ref": "#/$defs/fit_contract" },
    "extensions": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "prefixItems": [
        { "$ref": "#/$defs/rank_one" },
        { "$ref": "#/$defs/full_covariance" },
        { "$ref": "#/$defs/fourier_eof" },
        { "$ref": "#/$defs/vector_ar" },
        { "$ref": "#/$defs/gaussian_hmm" },
        { "$ref": "#/$defs/spectral" },
        { "$ref": "#/$defs/counterfactual" }
      ],
      "items": false
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "git_commit": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "finite_number": {
      "type": "number"
    },
    "vector": {
      "type": "array",
      "items": { "$ref": "#/$defs/finite_number" }
    },
    "matrix": {
      "type": "array",
      "items": { "$ref": "#/$defs/vector" }
    },
    "source_lineage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_snapshot_id",
        "product",
        "product_version",
        "doi",
        "retrieval_date",
        "archive_path",
        "archive_sha256",
        "decompressed_sha256",
        "requested_location",
        "returned_grid",
        "header",
        "variables",
        "fit_period",
        "heldout_excluded_after",
        "calendar_transform"
      ],
      "properties": {
        "source_snapshot_id": { "const": "daymet_v4r1_a5a17_fit1980_2009_noleap_v1" },
        "product": { "const": "Daymet V4 R1 daily" },
        "product_version": { "const": "4.1" },
        "doi": { "const": "10.3334/ORNLDAAC/2129" },
        "retrieval_date": { "type": "string", "format": "date" },
        "archive_path": { "type": "string", "minLength": 1 },
        "archive_sha256": { "$ref": "#/$defs/sha256" },
        "decompressed_sha256": { "$ref": "#/$defs/sha256" },
        "requested_location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitude_deg", "longitude_deg", "station_elevation_ft"],
          "properties": {
            "latitude_deg": { "$ref": "#/$defs/finite_number" },
            "longitude_deg": { "$ref": "#/$defs/finite_number" },
            "station_elevation_ft": { "$ref": "#/$defs/finite_number" }
          }
        },
        "returned_grid": {
          "type": "object",
          "additionalProperties": false,
          "required": ["latitude_deg", "longitude_deg", "x_m", "y_m", "tile", "elevation_m"],
          "properties": {
            "latitude_deg": { "$ref": "#/$defs/finite_number" },
            "longitude_deg": { "$ref": "#/$defs/finite_number" },
            "x_m": { "$ref": "#/$defs/finite_number" },
            "y_m": { "$ref": "#/$defs/finite_number" },
            "tile": { "type": "integer", "minimum": 1 },
            "elevation_m": { "type": "integer" }
          }
        },
        "header": {
          "type": "object",
          "additionalProperties": false,
          "required": ["software_version", "selection", "citation"],
          "properties": {
            "software_version": { "const": "4.0" },
            "selection": { "const": "All years; all variables" },
            "citation": { "type": "string", "minLength": 1 }
          }
        },
        "variables": {
          "type": "array",
          "prefixItems": [
            { "const": "prcp_mm_day" },
            { "const": "tmax_deg_c" },
            { "const": "tmin_deg_c" }
          ],
          "items": false,
          "minItems": 3,
          "maxItems": 3
        },
        "fit_period": {
          "type": "array",
          "prefixItems": [{ "const": 1980 }, { "const": 2009 }],
          "items": false,
          "minItems": 2,
          "maxItems": 2
        },
        "heldout_excluded_after": { "const": 2009 },
        "calendar_transform": { "const": "noleap_365_v1" }
      }
    },
    "fit_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "coefficient_payload_schema",
        "fit_recipe_id",
        "implementation_base_commit",
        "fitter_sha256",
        "python_version",
        "numpy_version",
        "scipy_version",
        "feature_order",
        "precipitation_transform",
        "temperature_transform",
        "detrending",
        "usable_years",
        "fit_seed"
      ],
      "properties": {
        "coefficient_payload_schema": { "const": "a5b_interannual_coefficients_v1" },
        "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
        "implementation_base_commit": { "$ref": "#/$defs/git_commit" },
        "fitter_sha256": { "$ref": "#/$defs/sha256" },
        "python_version": { "type": "string", "minLength": 1 },
        "numpy_version": { "type": "string", "minLength": 1 },
        "scipy_version": { "type": "string", "minLength": 1 },
        "feature_order": {
          "type": "array",
          "minItems": 36,
          "maxItems": 36,
          "items": { "type": "string", "minLength": 1 }
        },
        "precipitation_transform": { "const": "monthly_log1p_total_mm_centered_v1" },
        "temperature_transform": { "const": "monthly_mean_deg_c_centered_v1" },
        "detrending": { "const": "center_only_raw_v1" },
        "usable_years": { "const": 30 },
        "fit_seed": { "const": "none_deterministic_v1" }
      }
    },
    "diagnostics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fit_status", "warnings", "interventions", "serialized_numeric_count", "payload_sha256"],
      "properties": {
        "fit_status": { "const": "ok" },
        "warnings": { "type": "array", "items": { "type": "string" } },
        "interventions": { "type": "array", "items": { "type": "string" } },
        "serialized_numeric_count": { "type": "integer", "minimum": 1 },
        "payload_sha256": { "$ref": "#/$defs/sha256" },
        "retained_rank": { "type": "integer", "minimum": 1 },
        "explained_variance_fraction": { "$ref": "#/$defs/finite_number" },
        "reconstruction_rmse": { "$ref": "#/$defs/finite_number" },
        "minimum_eigenvalue": { "$ref": "#/$defs/finite_number" },
        "maximum_eigenvalue": { "$ref": "#/$defs/finite_number" },
        "em_iterations": { "type": "integer", "minimum": 1 },
        "em_log_likelihood": { "$ref": "#/$defs/finite_number" },
        "em_penalized_objective": { "$ref": "#/$defs/finite_number" }
      }
    },
    "extension_common": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate_id",
        "station_model",
        "generation_profile",
        "coefficient_payload_schema_version",
        "fit_recipe_id",
        "fit_identity_sha256",
        "runtime_parameter_count",
        "payload",
        "diagnostics"
      ],
      "properties": {
        "candidate_id": { "type": "string" },
        "station_model": { "type": "string" },
        "generation_profile": { "type": "string" },
        "coefficient_payload_schema_version": { "type": "integer" },
        "fit_recipe_id": { "type": "string" },
        "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
        "runtime_parameter_count": { "type": "integer", "minimum": 1 },
        "payload": { "type": "object" },
        "diagnostics": { "$ref": "#/$defs/diagnostics" }
      }
    },
    "rank_one": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "rank_one_monthly_sd" },
            "station_model": { "const": "interannual_rank_one_monthly_sd_v1" },
            "generation_profile": { "const": "a5b_rank_one_monthly_sd_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "const": 36 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["standard_deviations"],
              "properties": { "standard_deviations": { "$ref": "#/$defs/vector" } }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "full_covariance": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "full_monthly_covariance" },
            "station_model": { "const": "interannual_full_monthly_covariance_v1" },
            "generation_profile": { "const": "a5b_full_monthly_covariance_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "const": 666 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["cholesky_lower"],
              "properties": { "cholesky_lower": { "$ref": "#/$defs/matrix" } }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "fourier_eof": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "fourier_eof" },
            "station_model": { "const": "interannual_fourier_eof_v1" },
            "generation_profile": { "const": "a5b_fourier_eof_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "type": "integer", "minimum": 108, "maximum": 360 },
            "payload": { "$ref": "#/$defs/eof_payload" },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "eof_payload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rank", "reconstruction"],
      "properties": {
        "rank": { "type": "integer", "minimum": 3, "maximum": 10 },
        "reconstruction": { "$ref": "#/$defs/matrix" }
      }
    },
    "vector_ar": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "vector_ar" },
            "station_model": { "const": "interannual_fourier_eof_var1_v1" },
            "generation_profile": { "const": "a5b_vector_ar_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "type": "integer", "minimum": 1 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rank", "reconstruction", "transition", "innovation_cholesky_lower", "warmup_years"],
              "properties": {
                "rank": { "type": "integer", "minimum": 3, "maximum": 10 },
                "reconstruction": { "$ref": "#/$defs/matrix" },
                "transition": { "$ref": "#/$defs/matrix" },
                "innovation_cholesky_lower": { "$ref": "#/$defs/matrix" },
                "warmup_years": { "const": 256 }
              }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "gaussian_hmm": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "gaussian_hmm" },
            "station_model": { "const": "interannual_fourier_eof_hmm2_v1" },
            "generation_profile": { "const": "a5b_gaussian_hmm_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "type": "integer", "minimum": 1 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rank", "reconstruction", "transition", "stationary", "emission_means", "emission_standard_deviations"],
              "properties": {
                "rank": { "type": "integer", "minimum": 3, "maximum": 10 },
                "reconstruction": { "$ref": "#/$defs/matrix" },
                "transition": { "$ref": "#/$defs/matrix" },
                "stationary": { "$ref": "#/$defs/vector" },
                "emission_means": { "$ref": "#/$defs/matrix" },
                "emission_standard_deviations": { "$ref": "#/$defs/matrix" }
              }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "spectral": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "spectral_random_phase" },
            "station_model": { "const": "interannual_fourier_eof_spectral_v1" },
            "generation_profile": { "const": "a5b_spectral_random_phase_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "type": "integer", "minimum": 1 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rank", "reconstruction", "non_dc_amplitudes"],
              "properties": {
                "rank": { "type": "integer", "minimum": 3, "maximum": 10 },
                "reconstruction": { "$ref": "#/$defs/matrix" },
                "non_dc_amplitudes": { "$ref": "#/$defs/matrix" }
              }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    },
    "counterfactual": {
      "allOf": [
        { "$ref": "#/$defs/extension_common" },
        {
          "properties": {
            "candidate_id": { "const": "precip_counterfactual" },
            "station_model": { "const": "interannual_fourier_eof_precip_counterfactual_v1" },
            "generation_profile": { "const": "a5b_fourier_eof_precip_counterfactual_v1" },
            "coefficient_payload_schema_version": { "const": 1 },
            "fit_recipe_id": { "const": "a5b_monthly_state_fit_v1" },
            "fit_identity_sha256": { "$ref": "#/$defs/sha256" },
            "runtime_parameter_count": { "type": "integer", "minimum": 168, "maximum": 420 },
            "payload": {
              "type": "object",
              "additionalProperties": false,
              "required": ["rank", "reconstruction", "second_order_wet_probabilities", "amount_rank_rho"],
              "properties": {
                "rank": { "type": "integer", "minimum": 3, "maximum": 10 },
                "reconstruction": { "$ref": "#/$defs/matrix" },
                "second_order_wet_probabilities": { "$ref": "#/$defs/matrix" },
                "amount_rank_rho": { "$ref": "#/$defs/vector" }
              }
            },
            "diagnostics": { "$ref": "#/$defs/diagnostics" }
          }
        }
      ]
    }
  }
}
