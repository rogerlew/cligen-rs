#!/usr/bin/env python3
"""Repository-local launcher for the synthetic-only A9 research harness."""

import sys
from pathlib import Path

script_directory = Path(__file__).resolve().parent
sys.path = [entry for entry in sys.path if Path(entry or ".").resolve() != script_directory]
sys.path.insert(0, str(script_directory.parents[1]))

from research.a9_harness.cli import main

raise SystemExit(main())
